---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  return docs.map((doc) => ({
    params: { slug: doc.id.replace(/\.(md|mdx)$/i, "") },
    props: { doc }
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
---

<SiteLayout title={`${doc.data.title} | ForgeLens Docs`} description={doc.data.description}>
  <section class="shell section">
    <article class="info-card doc-prose">
      <p class="label">Documentation</p>
      <h1 class="doc-title">{doc.data.title}</h1>
      <p class="doc-description">{doc.data.description}</p>
      <Content />
      <p style="margin-top: 28px;">
        <a class="button" href="/docs">Back to docs</a>
      </p>
    </article>
  </section>
</SiteLayout>
