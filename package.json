{
  "name": "forgelens",
  "version": "0.2.0",
  "description": "Provider-agnostic local-first CLI that scans repositories and generates clean AI coding context files with evidence and confidence.",
  "type": "module",
  "bin": {
    "forgelens": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "assets/forgelens-hero.png",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm,cjs --dts --clean --out-dir dist",
    "dev": "tsx src/cli.ts",
    "help": "pnpm dev --help",
    "health": "pnpm dev check",
    "clean": "pnpm dev clear --yes",
    "save": "pnpm dev snapshot save --name main",
    "diff": "pnpm dev compare --from latest --out .forgelens",
    "ui": "pnpm dev ux",
    "context": "pnpm dev prompt",
    "fl": "pnpm dev",
    "s": "pnpm dev scan",
    "u": "pnpm dev ux",
    "ck": "pnpm dev check",
    "cl": "pnpm dev clear --yes",
    "sn": "pnpm dev snapshot save --name main",
    "cmp": "pnpm dev compare --from latest --out .forgelens",
    "pp": "pnpm dev prompt",
    "scan": "pnpm dev scan",
    "ux": "pnpm dev ux",
    "ui-ux": "pnpm dev ui-ux",
    "check": "pnpm dev check",
    "clear": "pnpm run clean",
    "snapshot": "pnpm dev snapshot save --name main",
    "compare": "pnpm run diff",
    "prompt": "pnpm run context",
    "lint": "biome lint src tests scripts",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false --organize-imports-enabled=false .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "release-check": "bash scripts/release-check.sh",
    "prepublishOnly": "pnpm release-check"
  },
  "keywords": [
    "ai",
    "codex",
    "cli",
    "repo",
    "static-analysis",
    "nextjs",
    "typescript",
    "agent-context"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tawachdev/forgelens.git"
  },
  "homepage": "https://github.com/tawachdev/forgelens#readme",
  "bugs": {
    "url": "https://github.com/tawachdev/forgelens/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.18",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
